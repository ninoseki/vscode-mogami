{
  "name": "vscode-mogami",
  "displayName": "Mogami",
  "version": "0.0.0",
  "description": "A VS Code extension for checking the latest version of each dependency",
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "gem",
    "npm",
    "pyproject",
    "python",
    "ruby"
  ],
  "author": "Manabu Niseki",
  "repository": {
    "type": "git",
    "url": "https://github.com/ninoseki/vscode-mogami.git"
  },
  "publisher": "ninoseki",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript",
    "dev": "NODE_ENV=development rollup -c rollup.config.ts --configPlugin typescript",
    "watch": "rollup -c rollup.config.ts --configPlugin typescript --watch",
    "coverage": "vitest run --coverage",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "package": "vsce package",
    "prepare": "husky",
    "publish": "vsce publish",
    "test": "vitest",
    "vscode:prepublish": "NODE_ENV=production rollup -c rollup.config.ts --configPlugin typescript"
  },
  "dependencies": {
    "@isaacs/ttlcache": "^2.1.5",
    "@renovatebot/pep440": "^5.0.0",
    "@renovatebot/ruby-semver": "^5.0.0",
    "compare-versions": "^6.1.1",
    "dockerfile-ast": "^0.7.1",
    "jsonc-parser": "^3.3.1",
    "linkedom": "^0.18.13",
    "neverthrow": "^8.2.0",
    "p-map": "^7.0.5",
    "semver": "^7.8.5",
    "toml-eslint-parser": "^1.0.3",
    "winston-transport-vscode": "^0.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ninoseki/eslint-plugin-neverthrow": "^0.2.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.10.15",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.80.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.1.0",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.73.0",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "type-fest": "^5.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.ts": [
      "npx oxlint --fix",
      "npx oxfmt"
    ]
  },
  "contributes": {
    "commands": [
      {
        "command": "vscode-mogami.clearCache",
        "title": "Clear cache",
        "category": "Mogami"
      },
      {
        "command": "vscode-mogami.icons.showingProgress",
        "title": "Analyzing dependencies...",
        "enablement": "false",
        "icon": "images/toggle-active-progress.svg",
        "category": "Mogami"
      },
      {
        "command": "vscode-mogami.icons.hide",
        "title": "Hide CodeLens",
        "icon": "images/toggle-active.svg",
        "category": "Mogami"
      },
      {
        "command": "vscode-mogami.icons.show",
        "title": "Show CodeLens",
        "icon": "images/toggle-inactive.svg",
        "category": "Mogami"
      },
      {
        "command": "vscode-mogami.setGitHubPersonalAccessToken",
        "title": "Set GitHub Personal Access Token",
        "category": "Mogami"
      },
      {
        "command": "vscode-mogami.deleteGitHubPersonalAccessToken",
        "title": "Delete GitHub Personal Access Token",
        "category": "Mogami"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vscode-mogami.icons.showingProgress",
          "when": "vscode-mogami.providerBusy === true && vscode-mogami.providerActive && !textCompareEditorVisible",
          "group": "navigation@1"
        },
        {
          "command": "vscode-mogami.icons.hide",
          "when": "vscode-mogami.providerBusy === false && vscode-mogami.providerActive && vscode-mogami.show === true && !textCompareEditorVisible",
          "group": "navigation@1"
        },
        {
          "command": "vscode-mogami.icons.show",
          "when": "vscode-mogami.providerBusy === false && vscode-mogami.providerActive && vscode-mogami.show === false && !textCompareEditorVisible",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "properties": {
        "vscode-mogami.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Whether to enable CodeLens globally or not."
        },
        "vscode-mogami.disableHover": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": [
              "docker-compose",
              "dockerfile",
              "gemfile",
              "gemspec",
              "github-actions-workflow",
              "npm",
              "pep723",
              "pre-commit-config",
              "pip-requirements",
              "pyproject",
              "shards"
            ]
          },
          "uniqueItems": true,
          "description": "Project formats for which the hover provider should be disabled. Useful when another extension already provides hover for that format (e.g. set to [\"npm\"] to avoid conflicting with vscode.npm on package.json)."
        },
        "vscode-mogami.disableCodeLens": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": [
              "docker-compose",
              "dockerfile",
              "gemfile",
              "gemspec",
              "github-actions-workflow",
              "npm",
              "pep723",
              "pre-commit-config",
              "pip-requirements",
              "pyproject",
              "shards"
            ]
          },
          "uniqueItems": true,
          "description": "Project formats for which the CodeLens provider should be disabled."
        },
        "vscode-mogami.concurrency": {
          "type": "integer",
          "default": 5,
          "description": "Concurrency (a number of concurrent requests) to get package data."
        },
        "vscode-mogami.usePrivateSource": {
          "type": "boolean",
          "default": true,
          "description": "Whether to use a private package source (repository) if it's set or not."
        },
        "vscode-mogami.showPrerelease": {
          "type": "boolean",
          "default": false,
          "description": "Whether to show a prerelease version or not."
        },
        "vscode-mogami.gitHubPersonalAccessToken": {
          "type": [
            "null",
            "string"
          ],
          "default": null,
          "description": "GitHub PAT for interacting with GitHub REST API."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:**/*.Dockerfile",
    "workspaceContains:**/*.gemspec",
    "workspaceContains:**/.github/workflows/*.{yaml,yml}",
    "workspaceContains:**/.pre-commit-config.{yaml,yml}",
    "workspaceContains:**/Containerfile",
    "workspaceContains:**/Dockerfile",
    "workspaceContains:**/Dockerfile.*",
    "workspaceContains:**/Gemfile",
    "workspaceContains:**/compose.*.{yaml,yml}",
    "workspaceContains:**/compose.{yaml,yml}",
    "workspaceContains:**/docker-compose.*.{yaml,yml}",
    "workspaceContains:**/docker-compose.{yaml,yml}",
    "workspaceContains:**/package.json",
    "workspaceContains:**/pyproject.toml",
    "workspaceContains:**/shard.yml",
    "workspaceContains:**/{requirements.txt,requirements-*.txt,*-requirements.txt,*.requirements.txt,constraints.txt}"
  ],
  "icon": "./images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  }
}
